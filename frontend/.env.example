# Optional override. By default frontend will call:
# ${VITE_SUPABASE_URL}/functions/v1/${VITE_SUPABASE_FUNCTION_NAME}
VITE_API_URL=
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_FUNCTION_NAME=ezyai-api
# Optional (local dev only): comma-separated backend fallbacks if Edge Function is not deployed yet.
VITE_LOCAL_API_FALLBACKS=http://localhost:4300/api,http://localhost:4302/api
# Never use service role key in frontend
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
